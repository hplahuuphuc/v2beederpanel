<%- include('../components/template') %>
<main id="content">
    <style>
        /* Theme Vàng Gold & Dark */
        :root {
            --gold-primary: #fbbf24;
            --gold-hover: #f59e0b;
            --gold-bg: rgba(251, 191, 36, 0.1);
        }

        .subuser-list {
            display: block;
            margin-top: 1rem;
        }

        .subuser-list-item {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            transition: all 0.2s ease;
            margin-bottom: 0.5rem;
            background-color: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .subuser-list-item:hover {
            background-color: rgba(255, 255, 255, 0.08);
            border-color: var(--gold-bg);
            transform: translateX(4px);
        }

        .subuser-list-item .icon {
            margin-right: 0.75rem;
            color: var(--gold-primary);
        }

        .subuser-list-item .name {
            flex-grow: 1;
            color: #f3f4f6;
            font-weight: 500;
        }

        .subuser-list-item .user-id {
            color: #9ca3af;
            font-size: 0.75rem;
            margin-right: 1.5rem;
            font-family: 'JetBrains Mono', monospace;
            background: rgba(0,0,0,0.2);
            padding: 2px 6px;
            border-radius: 4px;
        }

        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: rgba(0, 0, 0, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            z-index: 100;
            backdrop-filter: blur(8px);
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background: #111827;
            border-radius: 1.25rem;
            width: 100%;
            max-width: 26rem;
            padding: 2rem;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            transform: translateY(20px);
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            border: 1px solid rgba(251, 191, 36, 0.2);
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0);
        }

        .empty-state {
            text-align: center;
            padding: 3rem 0;
        }

        .empty-state-icon {
            width: 5rem;
            height: 5rem;
            margin: 0 auto 1.25rem;
            background: var(--gold-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .empty-state-icon svg {
            width: 2.5rem;
            height: 2.5rem;
            color: var(--gold-primary);
        }

        .btn {
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.625rem;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--gold-primary);
            color: #000;
            padding: 0.625rem 1.5rem;
        }

        .btn-primary:hover {
            background: var(--gold-hover);
            box-shadow: 0 0 15px rgba(251, 191, 36, 0.4);
        }

        .btn-secondary {
            background-color: #374151;
            color: white;
            padding: 0.625rem 1.5rem;
        }

        .btn-danger {
            background-color: rgba(220, 38, 38, 0.15);
            color: #f87171;
            border: 1px solid rgba(220, 38, 38, 0.2);
            padding: 0.375rem 1rem;
            font-size: 0.813rem;
        }

        .btn-danger:hover {
            background-color: #dc2626;
            color: white;
        }

        .form-input {
            width: 100%;
            padding: 0.75rem 1rem;
            background-color: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            color: white;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--gold-primary);
            box-shadow: 0 0 0 2px var(--gold-bg);
        }

        .action-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .action-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--gold-primary);
        }
    </style>

    <%- include('../components/instance') %>

    <div class="bg-gray-800/40 rounded-2xl p-8 mb-6 border border-white/5 backdrop-blur-md">
        <div class="action-bar">
            <h2 class="action-title">Người Dùng Phụ</h2>
            <button id="addSubuser" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Thêm Thành Viên
            </button>
        </div>

        <div class="subuser-list">
            <% if (users.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Chưa có người dùng nào</h3>
                    <p class="text-gray-400">Thêm người dùng phụ để cấp quyền quản lý máy chủ cùng bạn.</p>
                </div>
            <% } else { %>
                <% users.forEach(function(user) { %>
                    <div class="subuser-list-item">
                        <div class="icon">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <span class="name"><%= user.username %></span>
                        <span class="user-id">ID: <%= user.userId %></span>
                        <button class="btn btn-danger" onclick="confirmRemove('<%= user.username %>')">
                            Gỡ bỏ
                        </button>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <div id="add-subuser-modal" class="modal-overlay">
        <div class="modal-content">
            <h3 class="text-2xl font-bold mb-2 text-white">Thêm Thành Viên</h3>
            <p class="text-gray-400 text-sm mb-6">Nhập chính xác tên tài khoản bạn muốn thêm.</p>
            
            <form id="add-subuser-form">
                <div class="mb-6">
                    <label for="username" class="block text-sm font-medium text-gray-300 mb-2">Tên người dùng</label>
                    <input type="text" id="username" name="username" required class="form-input" placeholder="Ví dụ: nenvang_gold">
                </div>
                <div class="flex justify-end space-x-3">
                    <button type="button" id="cancel-add" class="btn btn-secondary">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary">Xác nhận thêm</button>
                </div>
            </form>
        </div>
    </div>
</main>

<script>
    const modal = document.getElementById('add-subuser-modal');
    
    // Mở/Đóng Modal
    document.getElementById('addSubuser').addEventListener('click', () => {
        modal.classList.add('active');
        document.getElementById('username').focus();
    });

    document.getElementById('cancel-add').addEventListener('click', () => {
        modal.classList.remove('active');
    });

    // Xác nhận gỡ người dùng (Thay thế alert bằng confirm mặc định nhưng có thể tùy biến sau)
    function confirmRemove(username) {
        if (confirm(`Bạn có chắc chắn muốn gỡ quyền truy cập của "${username}" không?`)) {
            location.href = `/instance/<%= req.params.id %>/users/remove/${username}`;
        }
    }

    // Xử lý Form
    document.getElementById('add-subuser-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const usernameInput = document.getElementById('username');
        const username = usernameInput.value.trim();
        const currentUsername = '<%= req.user.username %>';

        if (username === currentUsername) {
            alert("Bạn không thể tự thêm chính mình làm người dùng phụ!");
            return;
        }

        try {
            const response = await fetch(`/instance/<%= req.params.id %>/users/add`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username })
            });

            if (response.ok) {
                modal.classList.remove('active');
                window.location.reload();
            } else {
                const data = await response.json();
                alert(data.message || 'Không tìm thấy người dùng này hoặc có lỗi xảy ra.');
            }
        } catch (err) {
            alert('Lỗi kết nối đến máy chủ.');
        }
    });

    // Đóng khi click ngoài vùng modal
    window.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.remove('active');
    });
</script>