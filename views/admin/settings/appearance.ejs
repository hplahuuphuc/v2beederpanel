<%- include('../../components/admin_template') %>

<main class="relative bg-black min-h-screen text-neutral-200">
  <div class="px-6 pt-6 pb-4 border-b border-amber-900/50 bg-gradient-to-r from-black via-neutral-900 to-amber-950/20">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-yellow-500 to-amber-200 flex items-center gap-2 drop-shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <%= req.translations.settings || 'Cài Đặt Hệ Thống' %>
        </h1>
        <p class="mt-1 text-sm text-amber-500/60 italic">Tùy chỉnh các thiết lập chung cho trang quản trị Draco.</p>
      </div>
      <div class="flex items-center gap-2">
        <span class="px-3 py-1 bg-amber-950/30 border border-amber-800/50 rounded-full text-xs font-medium text-amber-400 flex items-center gap-1 shadow-[0_0_10px_rgba(251,191,36,0.1)]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Đã tự động lưu thay đổi
        </span>
      </div>
    </div>
  </div>

  <%- include('../../components/settings') %>

  <div class="px-6 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <div class="bg-neutral-900/50 rounded-xl border border-amber-900/30 overflow-hidden transition-all duration-300 hover:border-amber-500/50 hover:shadow-[0_0_20px_rgba(180,130,50,0.15)] group">
        <div class="px-5 py-4 border-b border-amber-900/30 bg-gradient-to-b from-neutral-800/50 to-transparent">
          <h2 class="text-lg font-semibold text-amber-200 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
            </svg>
            Thương Hiệu Panel
          </h2>
        </div>
        <div class="p-5 space-y-6">
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="panel-name" class="block text-sm font-medium text-amber-100/70">Tên Panel</label>
              <span class="text-[10px] uppercase tracking-wider text-amber-600 font-bold">Tối đa 32 ký tự</span>
            </div>
            <form action="/admin/settings/change/name" method="POST" class="flex gap-2">
              <div class="relative flex-1">
                <input 
                  id="panel-name" 
                  name="name" 
                  type="text" 
                  value="<%= name %>"
                  maxlength="32"
                  class="w-full bg-black/40 border border-amber-900/50 rounded-lg px-4 py-2.5 text-sm text-white placeholder-neutral-600 focus:outline-none focus:ring-1 focus:ring-amber-500 focus:border-amber-500 transition"
                  placeholder="Nhập tên panel của bạn..."
                  required>
              </div>
              <button 
                type="submit"
                class="bg-gradient-to-b from-amber-400 to-amber-600 hover:from-amber-300 hover:to-amber-500 text-black px-4 py-2 rounded-lg text-sm font-bold transition-all shadow-lg active:scale-95 whitespace-nowrap">
                Lưu
              </button>
            </form>
          </div>

          <div>
            <label class="block text-sm font-medium text-amber-100/70 mb-2">Logo Hệ Thống</label>
            <form action="/admin/settings/change/logo" method="POST" enctype="multipart/form-data" class="space-y-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="relative">
                    <input id="use-image" name="useImage" type="checkbox" class="hidden peer" onchange="document.getElementById('image-upload-box').classList.toggle('hidden')">
                    <label for="use-image" class="w-12 h-6 flex items-center bg-neutral-800 rounded-full p-1 cursor-pointer duration-300 peer-checked:bg-amber-600 shadow-inner">
                      <div class="bg-white w-4 h-4 rounded-full shadow-md transform duration-300 peer-checked:translate-x-6"></div>
                    </label>
                  </div>
                  <span class="text-sm text-neutral-400">Sử dụng ảnh tùy chỉnh</span>
                </div>
              </div>

              <div id="image-upload-box" class="hidden">
                <div class="flex flex-col gap-3">
                  <label for="logo-upload" class="cursor-pointer bg-neutral-800/50 hover:bg-neutral-700/50 border border-dashed border-amber-900/50 rounded-lg px-4 py-6 text-center transition group">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-amber-600 group-hover:text-amber-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs text-neutral-400 block" id="file-name">Chọn tệp hình ảnh (PNG, JPG, SVG)</span>
                    <input type="file" name="logo" id="logo-upload" class="hidden" onchange="previewLogo(event)">
                  </label>
                  <div id="logo-preview" class="hidden flex justify-center bg-black/20 p-2 rounded border border-amber-900/20">
                    <img id="preview-image" class="max-h-16" src="#" alt="Preview">
                  </div>
                </div>
              </div>

              <button type="submit" id="logo-submit-btn" class="w-full bg-neutral-800 hover:bg-amber-900/20 border border-amber-800/50 text-amber-400 px-4 py-2.5 rounded-lg text-sm font-medium transition disabled:opacity-30">
                Cập Nhật Logo
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="bg-neutral-900/50 rounded-xl border border-amber-900/30 overflow-hidden transition-all duration-300 hover:border-amber-500/50 hover:shadow-[0_0_20px_rgba(180,130,50,0.15)]">
        <div class="px-5 py-4 border-b border-amber-900/30 bg-gradient-to-b from-neutral-800/50 to-transparent">
          <h2 class="text-lg font-semibold text-amber-200 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Cài Đặt Đăng Ký
          </h2>
        </div>
        <div class="p-5 space-y-6">
          <div class="bg-black/30 p-4 rounded-lg border border-amber-900/20">
            <div class="flex items-center justify-between">
              <div>
                <label class="text-sm font-medium text-amber-100/80">Trang Đăng Ký</label>
                <p class="text-xs text-neutral-500 mt-1">
                  <%= settings.register ? 'Người dùng mới có thể tạo tài khoản' : 'Đang tạm dừng đăng ký mới' %>
                </p>
              </div>
              <form action="/admin/settings/toggle/register" method="POST">
                <input type="hidden" name="register" value="<%= !settings.register %>">
                <button type="submit" class="w-12 h-6 flex items-center bg-neutral-800 rounded-full p-1 duration-300 <%= settings.register ? 'bg-amber-600' : '' %> shadow-inner">
                  <div class="bg-white w-4 h-4 rounded-full shadow-md transform duration-300 <%= settings.register ? 'translate-x-6' : '' %>"></div>
                </button>
              </form>
            </div>
          </div>

          <div class="bg-black/30 p-4 rounded-lg border border-amber-900/20">
            <div class="flex items-center justify-between">
              <div>
                <label class="text-sm font-medium text-amber-100/80">Xác Minh Email</label>
                <p class="text-xs text-neutral-500 mt-1">Yêu cầu xác thực tài khoản qua email</p>
              </div>
              <form action="/admin/settings/toggle/force-verify" method="POST">
                <input type="hidden" name="forceVerify" value="<%= !settings.forceVerify %>">
                <button type="submit" class="w-12 h-6 flex items-center bg-neutral-800 rounded-full p-1 duration-300 <%= settings.forceVerify ? 'bg-amber-600' : '' %> shadow-inner">
                  <div class="bg-white w-4 h-4 rounded-full shadow-md transform duration-300 <%= settings.forceVerify ? 'translate-x-6' : '' %>"></div>
                </button>
              </form>
            </div>
          </div>
          
          <div class="bg-black/20 p-4 rounded-lg border border-neutral-800 opacity-60">
             <span class="text-xs font-bold text-amber-700 uppercase tracking-widest">Tính năng sắp ra mắt:</span>
             <div class="mt-2 flex justify-between text-xs text-neutral-500">
                <span>Mã mời (Invite Code)</span>
                <span class="italic text-[10px]">Đang phát triển...</span>
             </div>
          </div>
        </div>
      </div>

      <div class="bg-neutral-900/50 rounded-xl border border-amber-900/30 overflow-hidden transition-all duration-300 hover:border-amber-500/50 hover:shadow-[0_0_20px_rgba(180,130,50,0.15)]">
        <div class="px-5 py-4 border-b border-amber-900/30 bg-gradient-to-b from-neutral-800/50 to-transparent">
          <h2 class="text-lg font-semibold text-amber-200 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            Cấu Hình Nâng Cao
          </h2>
        </div>
        <div class="p-5 space-y-4">
          <div class="group bg-black/30 p-4 rounded-lg border border-amber-900/20 hover:border-amber-500/30 transition">
            <h3 class="text-sm font-medium text-amber-100 mb-1">Cài Đặt API</h3>
            <p class="text-[11px] text-neutral-500 mb-4 italic text-balance">Quản lý các khóa truy cập và giới hạn tốc độ yêu cầu từ hệ thống bên ngoài.</p>
            <a href="/admin/apikeys" class="block text-center w-full bg-amber-950/20 hover:bg-amber-600 hover:text-black border border-amber-500/30 text-amber-500 px-4 py-2 rounded-lg text-sm font-bold transition">
              Cấu Hình API
            </a>
          </div>

          <div class="bg-black/30 p-4 rounded-lg border border-neutral-800 opacity-50 grayscale">
            <h3 class="text-sm font-medium text-neutral-400 mb-1">Bảo Mật Hệ Thống</h3>
            <p class="text-[11px] text-neutral-600 mb-4">Cấu hình các chính sách bảo mật 2FA và lá chắn bảo vệ dữ liệu.</p>
            <button disabled class="w-full bg-neutral-800 text-neutral-600 px-4 py-2 rounded-lg text-sm font-medium cursor-not-allowed">
              Chưa Khả Dụng
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../../components/head') %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Character counter cho tên panel
    const panelNameInput = document.getElementById('panel-name');
    if (panelNameInput) {
      panelNameInput.addEventListener('input', function() {
        const counter = this.nextElementSibling;
        if (counter) {
          counter.textContent = `Còn ${32 - this.value.length} ký tự`;
        }
      });
    }

    // Xem trước Logo
    window.previewLogo = function(event) {
      const input = event.target;
      const fileName = document.getElementById('file-name');
      const preview = document.getElementById('logo-preview');
      const previewImage = document.getElementById('preview-image');
      const submitBtn = document.getElementById('logo-submit-btn');

      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          previewImage.src = e.target.result;
          preview.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.classList.add('bg-amber-600', 'text-black');
        }
        reader.readAsDataURL(input.files[0]);
        fileName.textContent = input.files[0].name;
      }
    };

    // Hiệu ứng Loading "Ánh Kim" khi lưu
    document.querySelectorAll('form').forEach(form => {
      form.addEventListener('submit', function() {
        const submitBtn = this.querySelector('button[type="submit"]');
        if (submitBtn) {
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML = `<span class="flex items-center gap-2"><svg class="animate-spin h-4 w-4 text-current" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang lưu...</span>`;
          submitBtn.disabled = true;
        }
      });
    });
  });
</script>