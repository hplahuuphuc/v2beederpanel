<%- include('../components/admin_template') %>

<main id="content" class="pb-20 bg-black min-h-screen">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 py-8 border-b border-amber-900/20">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-yellow-500 to-amber-200">
          <%= req.translations.images || 'Quản Lý Hình Ảnh Docker' %>
        </h1>
        <p class="mt-1 text-sm text-amber-600/50 italic">Cấu hình và nhập các mẫu container cho hệ thống của bạn.</p>
      </div>
      <button id="uploadimage" class="flex items-center gap-2 rounded-xl bg-gradient-to-b from-amber-400 to-amber-600 hover:from-amber-300 hover:to-amber-500 px-5 py-2.5 text-sm font-bold text-black shadow-[0_0_20px_rgba(251,191,36,0.3)] transition-all active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        <%= req.translations.importImage || 'Nhập Image (.json)' %>
      </button>
    </div>

    <div id="nodeTable" class="mt-8 bg-neutral-900/40 rounded-2xl border border-amber-900/30 overflow-hidden backdrop-blur-md shadow-2xl">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-amber-900/20">
          <thead class="bg-amber-950/20">
            <tr>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-amber-500 uppercase tracking-widest"><%= req.translations.name || 'Tên Image' %></th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-amber-500 uppercase tracking-widest hidden sm:table-cell"><%= req.translations.author || 'Tác Giả' %></th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-amber-500 uppercase tracking-widest hidden md:table-cell"><%= req.translations.dockerImage || 'Docker Image' %></th>
              <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-amber-500 uppercase tracking-widest"><%= req.translations.actions || 'Thao Tác' %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-amber-900/10">
            <% if (images.length === 0) { %>
              <tr>
                <td colspan="4" class="px-6 py-10 text-center text-sm text-neutral-500 italic">
                  <%= req.translations.noImagesFound || 'Chưa có Image nào được tải lên.' %>
                </td>
              </tr>
            <% } %>
            <% images.forEach(function(image) { %>
            <tr class="image-row group hover:bg-amber-500/5 transition-all cursor-pointer" data-image='<%= JSON.stringify(image) %>'>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-11 w-11 flex items-center justify-center rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-500 group-hover:bg-amber-500 group-hover:text-black transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-bold text-white group-hover:text-amber-400 transition-colors"><%= image.Name %></div>
                    <div class="text-[10px] text-neutral-500 font-mono"><%= image.Id.substring(0,8) %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-400 hidden sm:table-cell italic">
                <%= image.Author %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm hidden md:table-cell">
                <span class="px-3 py-1 rounded-lg bg-black/50 border border-amber-900/30 text-amber-200/70 font-mono text-xs"><%= image.Image %></span>
              </td>
              <td class="px-6 py-4 text-right">
                <button class="inline-flex items-center gap-1.5 rounded-lg bg-amber-900/20 border border-amber-500/30 px-3 py-1.5 text-xs font-bold text-amber-400 hover:bg-amber-500 hover:text-black transition-all">
                  Chi tiết
                </button>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <div id="imageDetail" class="hidden mt-8 animate-scale-in">
      <button id="backButton" class="flex items-center gap-2 text-amber-500/70 hover:text-amber-400 transition-colors duration-200 mb-6 font-bold uppercase text-xs tracking-widest">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Quay lại danh sách
      </button>

      <div class="bg-neutral-900/60 rounded-2xl border border-amber-900/30 p-8 shadow-2xl backdrop-blur-xl">
        <div class="flex flex-col md:flex-row gap-8">
          <div class="flex-shrink-0">
            <div class="h-32 w-32 rounded-2xl bg-gradient-to-br from-amber-500/20 to-transparent border border-amber-500/30 flex items-center justify-center text-amber-500 shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
          </div>

          <div class="flex-1">
            <div class="flex justify-between items-start">
              <h2 id="imageName" class="text-3xl font-bold text-white tracking-tight"></h2>
              <span id="dockerImageTag" class="px-3 py-1 rounded-full bg-amber-500 text-black text-[10px] font-black uppercase tracking-tighter">Docker</span>
            </div>
            <p id="imageDescription" class="mt-3 text-neutral-400 leading-relaxed"></p>

            <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-amber-900/20 pt-6">
              <div>
                <h3 class="text-[10px] font-black text-amber-500 uppercase tracking-[0.2em] mb-2">Docker Image Path</h3>
                <code id="dockerImage" class="text-sm text-amber-200/80 bg-black/40 px-3 py-1.5 rounded-lg border border-amber-900/20"></code>
              </div>
              <div>
                <h3 class="text-[10px] font-black text-amber-500 uppercase tracking-[0.2em] mb-2">Tác Giả</h3>
                <p id="authorInfo" class="text-sm text-neutral-300"></p>
              </div>
            </div>

            <div class="mt-10 flex flex-wrap gap-4">
              <button id="deleteImageButton" class="flex-1 md:flex-none flex items-center justify-center gap-2 rounded-xl bg-red-950/30 border border-red-900/50 hover:bg-red-900/50 px-6 py-3 text-sm font-bold text-red-500 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                Xóa Image
              </button>
              <button id="replaceImageButton" class="flex-1 md:flex-none flex items-center justify-center gap-2 rounded-xl bg-neutral-800 border border-amber-900/50 hover:bg-amber-950/30 px-6 py-3 text-sm font-bold text-amber-500 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                </svg>
                Thay thế bằng File mới
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<style>
/* Hiệu ứng scale mượt mà */
.animate-scale-in { animation: scaleIn 0.3s ease-out forwards; }
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.98); }
  to { opacity: 1; transform: scale(1); }
}

/* Scrollbar tùy chỉnh */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: #000; }
::-webkit-scrollbar-thumb { background: #451a03; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: #78350f; }
</style>

<script>
// Giữ nguyên logic JavaScript của bạn nhưng thêm phần xử lý UI mượt mà hơn
document.addEventListener("DOMContentLoaded", function() {
  const uploadBtn = document.getElementById('uploadimage');
  const imageRows = document.querySelectorAll('.image-row');
  const nodeTable = document.getElementById('nodeTable');
  const imageDetail = document.getElementById('imageDetail');
  const backButton = document.getElementById('backButton');

  // Logic hiển thị chi tiết
  imageRows.forEach(row => {
    row.addEventListener('click', function() {
      const currentImage = JSON.parse(this.dataset.image);
      
      document.getElementById('imageName').textContent = currentImage.Name;
      document.getElementById('imageDescription').textContent = currentImage.Description || 'Không có mô tả cho image này.';
      document.getElementById('dockerImage').textContent = currentImage.Image;
      document.getElementById('authorInfo').textContent = `${currentImage.Author} (${currentImage.AuthorName || 'N/A'})`;
      
      nodeTable.classList.add('hidden');
      imageDetail.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  backButton.addEventListener('click', () => {
    imageDetail.classList.add('hidden');
    nodeTable.classList.remove('hidden');
  });

  // Tích hợp Toast & Dialog sang trọng hơn (Giả định logic upload/delete giữ nguyên như mã gốc)
});
</script>