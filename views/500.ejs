<%- include('components/template') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.34.0/min/vs/loader.js"></script>

<style>
    .gold-gradient { background: linear-gradient(135deg, #BF953F, #FCF6BA, #B38728, #FBF5B7, #AA771C); }
    .gold-text { color: #D4AF37; }
    .gold-border { border-color: rgba(212, 175, 55, 0.3); }
    .gold-glow-box { box-shadow: 0 0 20px rgba(179, 135, 40, 0.15); }
    
    pre {
        white-space: pre-wrap;
        word-wrap: break-word;
        font-family: 'Fira Code', 'Courier New', monospace;
        border-left: 3px solid #D4AF37;
    }

    /* Hiệu ứng gợn sóng khi nhấn nút */
    .ripple {
        position: absolute;
        background: rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        transform: scale(0);
        animation: ripple 0.6s linear;
        pointer-events: none;
    }
    @keyframes ripple { to { transform: scale(4); opacity: 0; } }
</style>

<main id="content" class="min-h-screen bg-[#050505] text-gray-300">
    <div class="container mx-auto px-4 py-8 max-w-6xl">
        
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8 animate-fade-in">
            <div class="flex-1 min-w-0">
                <h1 class="text-2xl md:text-3xl font-bold text-white tracking-tight uppercase">
                    <%= req.translations.manageInstance %> <span class="gold-text">#System</span>
                </h1>
                <p class="mt-2 text-gray-500 text-sm md:text-base italic">
                    <%= req.translations.instanceViewDetailText %>
                </p>
            </div>
            
            <div class="flex gap-2 md:gap-3 flex-shrink-0">
                <button onclick="location.reload()" class="relative overflow-hidden px-4 py-2 gold-gradient text-black rounded-lg text-sm font-bold transition-all hover:scale-105 active:scale-95 shadow-lg flex items-center gap-2">
                    <i class="fas fa-sync-alt"></i>
                    <span class="hidden md:inline">Làm mới</span>
                </button>
            </div>
        </div>

        <div class="mb-10 opacity-90">
            <%- include('components/instance') %>
        </div>

        <div class="bg-[#0a0a0a] border gold-border rounded-2xl p-6 md:p-8 backdrop-blur-md gold-glow-box relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 gold-gradient opacity-5 blur-[80px]"></div>

            <div class="flex items-start gap-4 mb-6">
                <div class="p-3 rounded-xl bg-red-500/10 border border-red-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-white uppercase tracking-wider"><%= req.translations.fivezerozeroInstanceError %></h2>
                    <p class="text-gray-400 text-sm mt-1">Hệ thống ghi nhận một sự cố ngoài ý muốn. Đừng lo lắng, chúng tôi đang xử lý.</p>
                </div>
            </div>

            <div class="bg-black/40 rounded-xl border border-white/5 p-4 mt-4 shadow-inner">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em]"><%= req.translations.returnedTextError %></span>
                    <span class="px-2 py-0.5 rounded bg-red-500/20 text-red-400 text-[10px] font-mono">ERROR_LOG</span>
                </div>
                <pre class="text-red-400/90 font-mono text-xs md:text-sm bg-black/50 p-4 rounded-lg overflow-x-auto border border-red-900/20"><code><%= error || req.translations.informationAvailableError %></code></pre>
            </div>

            <div class="mt-8 pt-6 border-t border-white/5">
                <h3 class="text-xs font-bold text-[#D4AF37] mb-4 uppercase tracking-[0.3em]">Hành động gợi ý:</h3>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <button onclick="location.reload()" class="px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl text-sm font-medium transition-all flex items-center justify-center gap-2 group">
                        <i class="fas fa-redo text-gray-500 group-hover:gold-text"></i>
                        <span>Thử lại ngay</span>
                    </button>
                    
                    <button class="px-4 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded-xl text-sm font-medium transition-all flex items-center justify-center gap-2 group">
                        <i class="fas fa-terminal text-gray-500 group-hover:gold-text"></i>
                        <span>Xem Logs</span>
                    </button>
                    
                    <button class="px-4 py-3 gold-gradient text-black rounded-xl text-sm font-bold transition-all hover:brightness-110 flex items-center justify-center gap-2 shadow-lg">
                        <i class="fas fa-headset"></i>
                        <span>Liên hệ hỗ trợ</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('components/footer') %>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Hiệu ứng Ripple cho tất cả các nút bấm
        document.querySelectorAll('button').forEach(button => {
            button.style.position = 'relative';
            button.style.overflow = 'hidden';
            button.addEventListener('click', function(e) {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const ripple = document.createElement('span');
                ripple.className = 'ripple';
                ripple.style.left = `${x}px`;
                ripple.style.top = `${y}px`;
                
                this.appendChild(ripple);
                setTimeout(() => ripple.remove(), 600);
            });
        });
    });
</script>