<%- include('components/template') %>

<style>
  .gold-gradient-bg {
    background: linear-gradient(135deg, #BF953F, #FCF6BA, #B38728, #FBF5B7, #AA771C);
  }
  .gold-glow-border {
    box-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
    border: 1px solid rgba(212, 175, 55, 0.5);
  }
  .input-gold-focus:focus {
    border-color: #D4AF37;
    box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.2);
  }
  .text-gold {
    color: #D4AF37;
    text-shadow: 0px 2px 4px rgba(0,0,0,0.3);
  }
</style>

<main id="content" class="flex items-center justify-center min-h-[80vh]">
  <div class="max-w-md w-full bg-neutral-900/80 backdrop-blur-lg rounded-2xl shadow-2xl p-8 transform transition-all duration-500 gold-glow-border mt-16 border border-gray-800">
    
    <div class="flex flex-col items-center">
      <div class="p-3 rounded-full bg-[#D4AF37]/10 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#D4AF37]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h1 class="text-3xl font-extrabold text-center text-white tracking-tight uppercase">
        <%= req.translations.enable2FATitle %>
      </h1>
      <div class="h-1 w-16 gold-gradient-bg rounded-full mt-2"></div>
    </div>

    <p class="text-center text-gray-400 mt-6 px-2 text-sm leading-relaxed">
      <%= req.translations.enable2FADescription %>
    </p>

    <div class="flex justify-center my-8">
      <div class="relative group">
        <div class="absolute -inset-0.5 gold-gradient-bg rounded-xl blur opacity-30 group-hover:opacity-60 transition duration-1000"></div>
        <div class="relative bg-white p-3 rounded-xl shadow-inner">
          <img src="<%= qrCode %>" alt="QR Code for 2FA" class="w-44 h-44 object-cover">
        </div>
      </div>
    </div>

    <form action="/verify-2fa" method="POST" class="space-y-6">
      <div class="space-y-2">
        <label for="token" class="block text-xs font-bold text-[#D4AF37] uppercase tracking-widest ml-1">
          <%= req.translations.authCode %>
        </label>
        <input 
          type="text" 
          id="token" 
          name="token" 
          required 
          maxlength="6"
          placeholder="000000"
          class="block w-full px-6 py-4 bg-black/50 border border-gray-700 rounded-xl text-white text-center text-2xl tracking-[0.5em] font-mono focus:outline-none input-gold-focus transition-all duration-300 placeholder-gray-700"
        >
      </div>

      <div class="flex justify-center pt-2">
        <button 
          type="submit" 
          class="w-full gold-gradient-bg text-black font-bold py-4 px-6 rounded-xl shadow-[0_4px_15px_rgba(191,149,63,0.4)] hover:shadow-[0_6px_20px_rgba(191,149,63,0.6)] hover:scale-[1.02] active:scale-95 transition-all duration-300 uppercase tracking-wider"
        >
          <%= req.translations.verifyCode %>
        </button>
      </div>
    </form>
    
    <div class="mt-8 text-center">
      <p class="text-[10px] text-gray-600 uppercase tracking-tighter">Bảo mật đa lớp bởi hệ thống <%= name %></p>
    </div>
  </div>
</main>

<%- include('components/footer') %>