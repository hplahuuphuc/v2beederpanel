<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= name %></title>
    <% if (logo == true) { %>
        <link rel="icon" href="/assets/logo.png" type="image/x-icon">
    <% } %>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100..800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <style>
        :root {
            /* Palette Vàng Gold Hoàng Gia */
            --gold-light: #FCF6BA;
            --gold-medium: #D4AF37;
            --gold-dark: #AA771C;
            --header-bg: rgba(10, 10, 10, 0.85);
            --header-active: rgba(212, 175, 55, 0.15);
            --header-hover: rgba(255, 255, 255, 0.03);
            --header-text: rgba(255, 255, 255, 0.7);
            --header-text-active: #D4AF37;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #050505; /* Nền tối sâu hơn */
            color: rgba(255, 255, 255, 0.8);
            padding-top: 64px;
        }

        .gold-gradient {
            background: linear-gradient(135deg, #BF953F, #FCF6BA, #B38728, #FBF5B7, #AA771C);
        }

        /* Header nâng cấp */
        .header {
            background: var(--header-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(179, 135, 40, 0.2);
            height: 64px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .header.collapsed {
            height: 52px;
            background: rgba(10, 10, 10, 0.95);
        }

        .header-link {
            color: var(--header-text);
            transition: all 0.3s ease;
            border-radius: 0.75rem;
            position: relative;
        }

        .header-link:hover {
            background: var(--header-hover);
            color: white;
        }

        .header-link.active {
            background: var(--header-active);
            color: var(--header-text-active);
            box-shadow: inset 0 0 10px rgba(212, 175, 55, 0.1);
        }

        .header-link.active::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 20%;
            right: 20%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold-medium), transparent);
            border-radius: 2px;
        }

        .header-icon {
            transition: transform 0.3s ease;
        }

        .header-link:hover .header-icon {
            transform: translateY(-2px);
            color: var(--gold-medium);
        }

        /* Thanh loading mạ vàng */
        @keyframes loading {
            0% { width: 0%; opacity: 1; }
            90% { width: 100%; opacity: 1; }
            100% { width: 100%; opacity: 0; }
        }

        .loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(to right, #BF953F, #FCF6BA, #AA771C);
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
            animation: loading 0.8s ease-in-out forwards;
            z-index: 1000;
        }

        /* Scrollbar mạ vàng */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0a0a0a; }
        ::-webkit-scrollbar-thumb { 
            background: linear-gradient(#AA771C, #FCF6BA); 
            border-radius: 10px; 
        }

        .header-toggle {
            border: 1px solid rgba(179, 135, 40, 0.3);
            color: var(--gold-medium);
        }
    </style>
</head>

<body x-data="{ 
        headerCollapsed: localStorage.getItem('headerCollapsed') === 'true' 
    }" 
    :class="headerCollapsed ? 'header-collapsed' : ''">
    
    <div class="loading-bar"></div>

    <header class="header" :class="{'collapsed': headerCollapsed}">
        <div class="max-w-7xl mx-auto w-full flex items-center px-4 md:px-6">
            
            <div class="header-toggle w-8 h-8 rounded-lg flex items-center justify-center cursor-pointer hover:bg-white/5 transition-all mr-4" 
                 @click="headerCollapsed = !headerCollapsed; localStorage.setItem('headerCollapsed', headerCollapsed)">
                <i class="fas" :class="headerCollapsed ? 'fa-bars' : 'fa-times'"></i>
            </div>

            <div class="flex items-center mr-8 group cursor-pointer">
                <div class="w-9 h-9 rounded-xl gold-gradient flex items-center justify-center text-black shadow-[0_0_15px_rgba(212,175,55,0.3)] group-hover:rotate-12 transition-transform">
                    <i class="fas fa-crown text-lg"></i>
                </div>
                <span class="ml-3 font-bold text-white tracking-widest uppercase hidden sm:block" x-show="!headerCollapsed">
                    <%= name %>
                </span>
            </div>

            <nav class="flex items-center gap-1 md:gap-2">
                <a href="/instances" class="header-link flex items-center px-4 py-2 text-sm"
                   :class="{'active': window.location.pathname.includes('/instances')}">
                    <i class="fas fa-server mr-2 text-xs header-icon"></i>
                    <span x-show="!headerCollapsed" class="hidden md:inline">Máy chủ</span>
                </a>
                
                <a href="/account" class="header-link flex items-center px-4 py-2 text-sm"
                   :class="{'active': window.location.pathname.includes('/account')}">
                    <i class="fas fa-user-shield mr-2 text-xs header-icon"></i>
                    <span x-show="!headerCollapsed" class="hidden md:inline">Tài khoản</span>
                </a>
                
                <% if (req.user.admin === true) { %>
                <a href="/admin/overview" class="header-link flex items-center px-4 py-2 text-sm border border-red-500/20"
                   :class="{'active': window.location.pathname.includes('/admin')}">
                    <i class="fas fa-unlock-alt mr-2 text-xs text-red-500"></i>
                    <span x-show="!headerCollapsed" class="hidden md:inline font-bold">Quản trị</span>
                </a>
                <% } %>
            </nav>

            <div class="ml-auto flex items-center gap-4">
                <div class="hidden md:flex flex-col items-end mr-2" x-show="!headerCollapsed">
                    <span class="text-xs font-bold text-white uppercase"><%= user.username %></span>
                    <span class="text-[10px] text-[#D4AF37] tracking-[0.2em]">VIP MEMBER</span>
                </div>
                
                <div class="relative group">
                    <div class="w-10 h-10 rounded-full border-2 border-[#D4AF37]/50 p-0.5 overflow-hidden transition-all group-hover:border-[#D4AF37]">
                        <img src="https://ui-avatars.com/api/?name=<%= user.username %>&background=D4AF37&color=000" class="w-full h-full rounded-full object-cover">
                    </div>
                </div>

                <button onclick="window.location.href='/login'" class="w-8 h-8 flex items-center justify-center text-gray-500 hover:text-red-500 transition-colors">
                    <i class="fas fa-power-off text-sm"></i>
                </button>
            </div>
        </div>
    </header>

    <script>
        // Tự động ẩn loading bar
        window.addEventListener('load', () => {
            setTimeout(() => {
                const bar = document.querySelector('.loading-bar');
                if(bar) bar.style.display = 'none';
            }, 1000);
        });
    </script>
</body>
</html>